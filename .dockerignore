.venv/
venv/
env/
# .git/ is NOT excluded (item 8, audit-details+ package) — docker/Dockerfile's
# `version` stage reads it (git rev-parse --short HEAD) to compute the
# "dev (<short sha>)" fallback version for local builds without an explicit
# ABKIT_VERSION build-arg. Small cost (a few MB) shared by both Dockerfiles
# (same context "."), not worth a separate build context just to avoid it.
.github/
tests/
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.idea/
.vscode/
.claude/
*.md
!README.md
.env
.env.*
experiments/
ab_experiments/
.abkit_data/
*.csv
*.parquet

# frontend/Dockerfile делает npm ci заново внутри образа — node_modules из
# хоста никогда не нужен в build-контексте ни для backend, ни для
# frontend-образа (общий .dockerignore — на оба Dockerfile, context у обоих ".").
frontend/node_modules/
frontend/dist/
frontend/test-results/
frontend/playwright-report/
