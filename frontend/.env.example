# Локальная разработка: vite dev server (localhost:5173) проксирует /api на
# backend (localhost:8000) через vite.config.ts. VITE_API_BASE не нужен —
# пути в src/api/schema.ts уже содержат полный префикс "/api/v1/...", задавать
# его тут еще раз задваивает путь (см. комментарий в src/api/client.ts).
# Задавайте VITE_API_BASE, только если backend реально живет на другом origin
# (например VITE_API_BASE=http://api.example.com — БЕЗ /api/v1 на конце).
#VITE_API_BASE=
